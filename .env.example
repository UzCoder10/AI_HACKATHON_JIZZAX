# Nihol — muhit o'zgaruvchilari
# cp .env.example .env && qiymatlarni to'ldiring

# Ota-ona paneli mock (false = real API)
NEXT_PUBLIC_USE_MOCK=false

# Bola paneli mock (false = real API)
NEXT_PUBLIC_USE_CHILD_MOCK=false

# Demo bola ID — /child?childId= o'rniga (ixtiyoriy)
NEXT_PUBLIC_DEMO_CHILD_ID=

# ===== SERVER =====
PORT=
JWT_SECRET=
APP_URL=

# ===== PAYME (obuna to'lovi) =====
PAYME_MERCHANT_ID=
PAYME_SECRET_KEY=
PAYME_TEST_MODE=true

# ===== CLICK (obuna to'lovi) =====
CLICK_SERVICE_ID=
CLICK_MERCHANT_ID=
CLICK_MERCHANT_USER_ID=
CLICK_SECRET_KEY=

# Webhook URL (APP_URL + path):
# Payme:  POST {APP_URL}/api/webhooks/payme
# Click:  POST {APP_URL}/api/webhooks/click/prepare
#         POST {APP_URL}/api/webhooks/click/complete

# ===== GEMMA (AlemLLM) =====
ALEMLLM_API_URL=
ALEMLLM_API_KEY=
ALEMLLM_MODEL=

# ===== OPENAI =====
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ===== ANTHROPIC (Claude) =====
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# ===== AI PROVAYDER TANLOVI (alem | openai | anthropic) =====
# Masalan: matn uchun Claude, ovoz uchun OpenAI
AI_TEXT_PROVIDER=
AI_VOICE_PROVIDER=openai
AI_IMAGE_PROVIDER=anthropic
AI_MODERATION_PROVIDER=

# ===== YOUTUBE DATA API (dars video metadata) =====
YOUTUBE_API_KEY=

# ===== RAGFLOW =====
RAGFLOW_API_URL=
RAGFLOW_EMAIL=
RAGFLOW_PASSWORD=
RAGFLOW_API_KEY=
RAGFLOW_EMBEDDING_MODEL=
# Format: model_name@factory (masalan BAAI/bge-large-zh-v1.5@BAAI)
# Dataset yaratishda shu model RAGFlow serverda ruxsat etilgan bo'lishi kerak
RAGFLOW_DATASET_ID=

# ===== LANGFLOW =====
LANGFLOW_API_URL=
LANGFLOW_FLOW_ID=
LANGFLOW_API_KEY=

# ===== POSTGRESQL (Langflow infra — backend ishlatmaydi) =====
PG_HOST=
PG_PORT=
PG_DATABASE=
PG_USER=
PG_PASSWORD=

# Nihol Prisma (PostgreSQL connection string)
# O'zbekiston hududidagi server (.uz yoki ichki IP)
DATABASE_URL=

# Ma'lumotlar lokalizatsiyasi (production: UZ majburiy)
DATA_RESIDENCY_REGION=UZ

# Ota-ona paneli: mock ma'lumot (investor demo uchun true)
NEXT_PUBLIC_USE_MOCK=false

# Bola interfeysi mock (default: USE_MOCK=true bo'lsa yoki alohida true)
NEXT_PUBLIC_USE_CHILD_MOCK=true

# ===== MINIO (Langflow infra — backend ishlatmaydi) =====
MINIO_ENDPOINT=
MINIO_PORT=
MINIO_USE_SSL=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=
