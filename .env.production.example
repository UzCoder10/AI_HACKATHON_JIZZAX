# Nihol — PRODUCTION muhit o'zgaruvchilari
# cp .env.production.example .env.production && qiymatlarni to'ldiring
# Hech qachon git ga commit qilmang!

NODE_ENV=production

# ===== SERVER =====
PORT=3000
APP_URL=https://nihol.uz
JWT_SECRET=

# ===== MA'LUMOTLAR LOKALIZATSIYASI (majburiy) =====
# DB va MinIO O'zbekiston hududidagi serverlarga yo'naltirilishi kerak
DATA_RESIDENCY_REGION=UZ

# ===== DATABASE (O'zbekiston ichki server / .uz domen) =====
# Misol: postgresql://user:pass@db.nihol.internal.uz:5432/nihol?schema=safarai
DATABASE_URL=

# ===== MINIO (RAG hujjatlar — O'zbekiston) =====
MINIO_ENDPOINT=minio.nihol.uz
MINIO_PORT=9000
MINIO_USE_SSL=true
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=nihol-rag

# ===== ALEMLLM (O'zbekiston) =====
ALEMLLM_API_URL=
ALEMLLM_API_KEY=
ALEMLLM_MODEL=gemma4

# ===== OPENAI =====
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ===== ANTHROPIC (Claude) =====
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# ===== AI PROVAYDER TANLOVI =====
AI_TEXT_PROVIDER=
AI_VOICE_PROVIDER=openai
AI_IMAGE_PROVIDER=anthropic
AI_MODERATION_PROVIDER=

# ===== RAGFLOW =====
RAGFLOW_API_URL=
RAGFLOW_API_KEY=
RAGFLOW_DATASET_ID=
RAGFLOW_EMAIL=
RAGFLOW_PASSWORD=
RAGFLOW_EMBEDDING_MODEL=

# ===== LANGFLOW =====
LANGFLOW_API_URL=
LANGFLOW_FLOW_ID=
LANGFLOW_API_KEY=

# ===== TO'LOV =====
PAYME_MERCHANT_ID=
PAYME_SECRET_KEY=
PAYME_TEST_MODE=false

CLICK_SERVICE_ID=
CLICK_MERCHANT_ID=
CLICK_MERCHANT_USER_ID=
CLICK_SECRET_KEY=
